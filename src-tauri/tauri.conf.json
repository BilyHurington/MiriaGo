{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiriaGo",
  "version": "1.1.2",
  "identifier": "app.miriago.desktop",
  "build": {
    "beforeDevCommand": "flutter build web --debug",
    "beforeBuildCommand": "flutter build web --release",
    "frontendDist": "../build/web",
    "devUrl": "http://127.0.0.1:8791"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MiriaGo",
        "width": 430,
        "height": 860,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
